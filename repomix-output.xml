CREATE TABLE notification_preferences (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    user_id UUID NOT NULL UNIQUE,

    in_app_enabled BOOLEAN NOT NULL DEFAULT TRUE,

    FOREIGN KEY(user_id)
