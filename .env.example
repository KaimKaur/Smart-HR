# PostgreSQL (Docker Compose + local)
POSTGRES_USER=smart_hr
POSTGRES_PASSWORD=smart_hr_dev
POSTGRES_DB=smart_hr
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# PostgreSQL connection (async SQLAlchemy + asyncpg)
# Local: postgresql+asyncpg://smart_hr:smart_hr_dev@localhost:5432/smart_hr
# Docker backend service: postgresql+asyncpg://smart_hr:smart_hr_dev@db:5432/smart_hr
DATABASE_URL=

# Service ports (Docker Compose)
BACKEND_PORT=8000
FRONTEND_PORT=3000
HTTP_PORT=80

# JWT signing secrets — use long random strings in production (min 32 chars)
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password reset token lifetime in hours (default: 24)
PASSWORD_RESET_EXPIRE_HOURS=24

# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=http://localhost:3000

# Frontend API base (browser-reachable URL for local dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional JWT algorithm override (default: HS256)
# JWT_ALGORITHM=HS256

# Resume storage (relative to backend working directory)
# RESUME_UPLOAD_DIR=uploads/resumes

# AI screening (OpenAI-compatible API)
# OPENAI_API_KEY=
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1
# AI_MAX_TOKENS=1500
# AI_TEMPERATURE=0.2
# AI_AUTO_SCREEN_ON_UPLOAD=false

# After installing dependencies, download spaCy model:
# python -m spacy download en_core_web_sm
